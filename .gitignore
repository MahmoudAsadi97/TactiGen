# Environment — never commit secrets
.env
*.env

# Python artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Raw video files — copyright risk, too large for git
data/soccernet/**/*.mkv
data/soccernet/**/*.mp4
data/sample_clips/*.mp4
data/sample_clips/*.mkv
data/sample_clips/*.mov
data/sample_clips/*.avi

# Model weights — too large for git (use releases or DVC)
outputs/models/
*.pt
*.pth
*.ckpt
*.bin

# FAISS index (large binary)
knowledge/faiss_index/*.index
knowledge/faiss_index/*.pkl

# Generated outputs — reproduced by running the pipeline
outputs/reports/
outputs/visualizations/
outputs/run_logs/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# MLflow
mlruns/

# IDE
.vscode/
.idea/
